{
  "name": "astralforge-senior-engineer-skills",
  "version": "3.0.0",
  "private": true,
  "description": "Senior-grade AI engineering skills with local QA, security, and review gates.",
  "scripts": {
    "e2e": "playwright test",
    "test:e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "knip": "knip",
    "quality:ai": "bash scripts/ai-quality-checks.sh",
    "test:unit": "vitest run --reporter=dot",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage --reporter=dot",
    "typecheck": "tsc --noEmit",
    "quality:senior": "bash scripts/ai-senior-checks.sh",
    "mutation": "stryker run",
    "verify:skills": "bash scripts/verify-source-skills.sh",
    "audit:skills": "bash scripts/audit-skills.sh",
    "release:check-actions": "bash scripts/check-github-actions.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "knip": "^6.17.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "qs": "^6.15.2"
  }
}
