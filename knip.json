    "install*.sh",
    "verify*.sh",
    "e2e/**/*.spec.ts"
  ],
  "project": [
    "**/*.{js,jsx,ts,tsx,mjs,cjs}"
  ],
  "ignore": [
    "installer/extensions/**",
    "installer/skills/**",
    "skills/**"
  ]
}
